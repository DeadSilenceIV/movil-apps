# ==========================================================================
# .gitignore común para el repo (Flutter + React Native/Expo + herramientas)
# ==========================================================================

# --- Sistema operativo ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editores / IDE ---
.idea/
.vscode/
*.iml
*.swp
*.code-workspace

# ==========================================================================
# Flutter / Dart  (aplica dentro de flutter_app/)
# ==========================================================================
flutter_app/.dart_tool/
flutter_app/.packages
flutter_app/.pub-cache/
flutter_app/.pub/
flutter_app/build/
flutter_app/.flutter-plugins
flutter_app/.flutter-plugins-dependencies
flutter_app/pubspec.lock
flutter_app/coverage/

# Android
flutter_app/android/.gradle/
flutter_app/android/app/debug/
flutter_app/android/app/profile/
flutter_app/android/app/release/
flutter_app/android/local.properties
flutter_app/android/key.properties
**/*.keystore
**/*.jks

# iOS
flutter_app/ios/Pods/
flutter_app/ios/.symlinks/
flutter_app/ios/Flutter/Flutter.framework
flutter_app/ios/Flutter/Flutter.podspec
**/DerivedData/

# ==========================================================================
# React Native / Expo  (aplica dentro de react_native_app/)
# ==========================================================================
node_modules/
react_native_app/.expo/
react_native_app/.expo-shared/
react_native_app/dist/
react_native_app/web-build/
react_native_app/android/
react_native_app/ios/
*.orig.*
npm-debug.*
yarn-error.*

# Metro
.metro-health-check*

# EAS / builds
*.apk
*.aab
*.ipa

# ==========================================================================
# Entornos y secretos
# ==========================================================================
.env
.env.*
!.env.example

# --- Logs ---
*.log
logs/

# --- Documento de la actividad (no versionar) ---
*.docx
